<%= form_for(@admin_user, url: session_path) do |f| %>
  <div class="mb-3">
    <%= f.label @admin_user.class.login_column, class: "form-label" %>
    <%= f.text_field @admin_user.class.login_column, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :password, class: "form-label" %>
    <%= f.password_field :password, class: "form-control" %>
  </div>
  <%= f.submit translate_scoped("sessions.sign_in"), class: "btn btn-primary w-100" %>
<% end %>
