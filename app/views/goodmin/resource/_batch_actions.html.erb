<% if @resource_service.include_batch_actions? %>
  <%= link_to translate_scoped("batch_actions.buttons.select_all"), "#", class: "btn btn-outline-secondary",
    data: { batch_actions_target: "selectAll", action: "click->batch-actions#toggle" } %>
  <%= link_to translate_scoped("batch_actions.buttons.deselect_all"), "#", class: "btn btn-outline-secondary d-none",
    data: { batch_actions_target: "selectNone", action: "click->batch-actions#toggle" } %>

  <%= form_tag(url_for([*@resource_parents, @resource_class]), method: :patch,
      data: { batch_actions_target: "form", turbo: "false",
              resource_path: url_for([*@resource_parents, @resource_class]) }) do %>
    <div class="btn-group">
      <% @resource_service.batch_action_map.each do |name, options| %>
        <%= batch_action_button(name, options) %>
      <% end %>
    </div>
  <% end %>
<% end %>
